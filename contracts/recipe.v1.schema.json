{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mere.run/contracts/recipe.v1.schema.json",
  "title": "mere.run Recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "id",
    "title",
    "family",
    "description",
    "models",
    "dataset",
    "captioning",
    "training",
    "evaluation"
  ],
  "properties": {
    "contractVersion": {
      "const": "mere.run/recipe.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "family": {
      "enum": ["style-lora", "character-lora"]
    },
    "description": {
      "type": "string"
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "apply"],
      "properties": {
        "train": {
          "type": "string"
        },
        "apply": {
          "type": "string"
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "minImages", "preferredImages"],
      "properties": {
        "layout": {
          "const": "paired-image-caption-directory"
        },
        "minImages": {
          "type": "integer",
          "minimum": 1
        },
        "preferredImages": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "captioning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggerToken", "technique", "rules"],
      "properties": {
        "triggerToken": {
          "type": "string"
        },
        "technique": {
          "type": "string"
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": true,
      "required": ["command", "arguments"],
      "properties": {
        "command": {
          "const": "mere.run image train-lora"
        },
        "arguments": {
          "type": "object"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "prompts", "loraScales"],
      "properties": {
        "command": {
          "const": "mere.run image generate"
        },
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "loraScales": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}

