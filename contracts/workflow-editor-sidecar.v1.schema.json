{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mere.run/contracts/workflow-editor-sidecar.v1.schema.json",
  "title": "mere.run Workflow Editor Sidecar v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "viewport", "nodes"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "mere.run/workflow-editor"},
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "zoom"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "zoom": {"type": "number", "minimum": 0.1, "maximum": 4}
      }
    },
    "nodes": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "collapsed": {"type": "boolean"},
          "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
        }
      }
    },
    "outputs": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "collapsed": {"type": "boolean"},
          "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
        }
      }
    },
    "groups": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "width", "height", "title", "node_ids"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "width": {"type": "number", "minimum": 120},
          "height": {"type": "number", "minimum": 80},
          "title": {"type": "string"},
          "node_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}},
          "collapsed": {"type": "boolean"},
          "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
        }
      }
    },
    "notes": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "width", "height", "text"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "width": {"type": "number", "minimum": 120},
          "height": {"type": "number", "minimum": 80},
          "text": {"type": "string"},
          "collapsed": {"type": "boolean"},
          "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
        }
      }
    },
    "selection_sets": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_ids"],
        "properties": {
          "node_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}}
        }
      }
    }
  }
}
