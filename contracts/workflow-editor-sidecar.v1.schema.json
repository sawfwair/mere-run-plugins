{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mere.run/contracts/workflow-editor-sidecar.v1.schema.json",
  "title": "mere.run Workflow Editor Sidecar v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "viewport", "nodes"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "mere.run/workflow-editor"},
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "zoom"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "zoom": {"type": "number", "minimum": 0.1, "maximum": 4}
      }
    },
    "nodes": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]{0,63}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y"],
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "collapsed": {"type": "boolean"}
        }
      }
    }
  }
}
