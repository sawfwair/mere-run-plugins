{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mere.run/contracts/workflow-module.v1.schema.json",
  "title": "mere.run Workflow Module v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "parameters", "nodes", "outputs"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "mere.run/workflow-module"},
    "parameters": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "nodes": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "outputs": {"type": "object"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}
  }
}
